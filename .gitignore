# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── Distribution / packaging ──────────────────────────────────────────────────
dist/
build/
*.egg-info/
*.egg
MANIFEST

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
.env/

# ── Test & coverage ───────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/

# ── Type checkers ─────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.user

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Project-specific ──────────────────────────────────────────────────────────
